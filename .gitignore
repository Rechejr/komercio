*.tsbuildinfo

# ─── LOGS ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── TESTS & COVERAGE ────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── SISTEMA OPERATIVO ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ─── ARCHIVOS TEMPORALES DE OFFICE ───────────────────────────────────────────
