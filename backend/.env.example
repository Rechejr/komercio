# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/komercio_db?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Resend — https://resend.com, API keys en Dashboard > API Keys)
# SMTP directo se abandonó: varios hosts (Railway incluido) bloquean el
# puerto SMTP saliente. Resend envía por HTTPS, que nunca se bloquea.
RESEND_API_KEY=re_your_api_key
# Requiere verificar el dominio en Resend (Dashboard > Domains) para poder
# enviar a cualquier destinatario — sin verificar, solo se puede enviar al
# correo dueño de la cuenta de Resend, útil para probar.
EMAIL_FROM="Komercio <noreply@tudominio.com>"

# Cloudinary (imágenes de productos y logo del negocio)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# App
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Sentry — monitoreo de errores en producción (opcional)
# Crear cuenta gratis en https://sentry.io y obtener el DSN del proyecto
SENTRY_DSN=
