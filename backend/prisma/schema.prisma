generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ROLES ────────────────────────────────────────────────────────────────────
enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  CASHIER
  SELLER
  WAREHOUSE
}

// ─── ESTADOS GENERALES ────────────────────────────────────────────────────────
enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
}

enum CreditStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  CANCELLED
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  NEQUI
  DAVIPLATA
  CARD
  MIXED
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

// ─── USERS ────────────────────────────────────────────────────────────────────
model User {
  id                   String         @id @default(uuid())
  name                 String
  email                String         @unique
  phone                String?
  password             String
  googleId             String?        @unique
  role                 UserRole       @default(CASHIER)
  isActive             Boolean        @default(true)
  isEmailVerified      Boolean        @default(false)
  emailVerifyToken     String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  avatar               String?
  lastLogin            DateTime?
  refreshTokens        RefreshToken[]
  business             Business?      @relation("BusinessOwner")
  branchId             String?
  branch               Branch?        @relation(fields: [branchId], references: [id])
  createdBranches      Branch[]       @relation("BranchCreator")
  createdTransfers     StockTransfer[]
  cashMovements        CashMovement[]
  sales                Sale[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?

  @@index([email])
  @@index([branchId])
  @@index([emailVerifyToken])
  @@index([resetPasswordToken])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── BUSINESS ─────────────────────────────────────────────────────────────────
model Business {
  id                String            @id @default(uuid())
  name              String
  category          String?
  legalName         String?
  nit               String?
  phone             String?
  email             String?
  address           String?
  city              String?
  country           String            @default("Colombia")
  logo              String?
  currency          String            @default("COP")
  taxRate           Decimal           @default(0)
  ownerId           String            @unique
  owner             User              @relation("BusinessOwner", fields: [ownerId], references: [id])
  branches          Branch[]
  categories        Category[]
  customers         Customer[]
  suppliers         Supplier[]
  brands            Brand[]
  purchases         Purchase[]
  expenses          Expense[]
  expenseCategories ExpenseCategory[]
  products          Product[]
  stockTransfers    StockTransfer[]
  plan              String            @default("free")
  planExpiresAt     DateTime?
  settings          Json?
  paymentLinks      PaymentLink[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?

  @@map("businesses")
}

// ─── PAYMENT LINKS (Wompi) ─────────────────────────────────────────────────────
// Mapeo linkId → negocio que sobrevive más allá del TTL de Redis y no se pisa
// entre sí cuando se generan varios links seguidos (reintentos de checkout):
// antes esto vivía en un solo campo `business.settings.pendingPayment` que la
// siguiente llamada a createLink sobreescribía, así que si el webhook de un
// link viejo llegaba tarde (después de expirar el caché), ya no encontraba a
// qué negocio pertenecía y el pago quedaba cobrado sin activar el plan.
model PaymentLink {
  id         String    @id // Wompi payment_link_id
  businessId String
  business   Business  @relation(fields: [businessId], references: [id])
  period     String
  months     Int
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([businessId])
  @@map("payment_links")
}

model Branch {
  id            String         @id @default(uuid())
  name          String
  address       String?
  phone         String?
  businessId    String
  business      Business       @relation(fields: [businessId], references: [id])
  // Quién creó la sucursal — pista de auditoría; nunca se usa para autorizar nada,
  // solo para poder revisar el historial si algo se ve raro (ej. reventa de sucursal).
  createdById   String?
  createdBy     User?          @relation("BranchCreator", fields: [createdById], references: [id])
  users         User[]
  products      Product[]
  sales         Sale[]
  cashRegisters CashRegister[]
  purchases     Purchase[]
  inventoryMovements InventoryMovement[]
  productStocks ProductStock[]
  purchaseDetails PurchaseDetail[]
  transfersOut  StockTransfer[] @relation("TransferFrom")
  transfersIn   StockTransfer[] @relation("TransferTo")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  @@index([businessId])
  @@map("branches")
}

// ─── CATEGORIES & BRANDS ──────────────────────────────────────────────────────
model Category {
  id          String     @id @default(uuid())
  businessId  String?
  business    Business?  @relation(fields: [businessId], references: [id])
  name        String
  description String?
  color       String?
  icon        String?
  parentId    String?
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@unique([businessId, name])
  @@index([businessId])
  @@map("categories")
}

model Brand {
  id         String    @id @default(uuid())
  name       String
  logo       String?
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  products   Product[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  @@unique([businessId, name])
  @@index([businessId])
  @@map("brands")
}

// ─── PRODUCTS ─────────────────────────────────────────────────────────────────
model Product {
  id                 String              @id @default(uuid())
  // code is unique per business, not globally — two businesses can share the same code
  code               String
  barcode            String?
  name               String
  description        String?
  categoryId         String?
  category           Category?           @relation(fields: [categoryId], references: [id])
  brandId            String?
  brand              Brand?              @relation(fields: [brandId], references: [id])
  supplierId         String?
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  branchId           String?
  branch             Branch?             @relation(fields: [branchId], references: [id])
  businessId         String?
  business           Business?           @relation(fields: [businessId], references: [id])
  costPrice          Decimal             @default(0)
  salePrice          Decimal             @default(0)
  wholesalePrice     Decimal?
  // stock and minStock stay Float — they represent inventory quantities, not monetary values
  stock              Float               @default(0)
  minStock           Float               @default(0)
  unit               String              @default("unit")
  image              String?
  images             String[]
  taxRate            Decimal             @default(0)
  isActive           Boolean             @default(true)
  allowNegativeStock Boolean             @default(false)
  // Marca cuándo se notificó por última vez el stock bajo — evita reenviar la
  // misma alerta en cada venta mientras el stock sigue bajo el mínimo; se
  // limpia (null) cuando el producto se reabastece por encima del mínimo.
  lowStockNotifiedAt DateTime?
  saleDetails        SaleDetail[]
  purchaseDetails    PurchaseDetail[]
  inventoryMovements InventoryMovement[]
  // Total denominado en Product.stock = SUM(productStocks.stock) — se mantiene
  // sincronizado en cada venta/compra/ajuste/transferencia para que dashboard,
  // reportes, exportaciones, catálogo público y búsqueda sigan leyendo un solo
  // número sin tener que enterarse de que el stock ahora vive por bodega.
  productStocks      ProductStock[]
  transferItems      StockTransferItem[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?

  @@unique([businessId, code])
  @@index([businessId, barcode])
  @@index([businessId, name])
  @@index([businessId, isActive])
  @@index([categoryId])
  @@index([branchId])
  @@index([businessId])
  @@map("products")
}

// Stock real por bodega — un producto tiene una fila aquí por cada bodega
// donde tiene existencias. Product.stock sigue siendo el total (ver arriba).
model ProductStock {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id])
  stock     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, branchId])
  @@index([branchId])
  @@map("product_stocks")
}

model StockTransfer {
  id           String              @id @default(uuid())
  businessId   String
  business     Business            @relation(fields: [businessId], references: [id])
  fromBranchId String
  fromBranch   Branch              @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranchId   String
  toBranch     Branch              @relation("TransferTo", fields: [toBranchId], references: [id])
  createdById  String
  createdBy    User                @relation(fields: [createdById], references: [id])
  notes        String?
  items        StockTransferItem[]
  createdAt    DateTime            @default(now())

  @@index([businessId])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id         String        @id @default(uuid())
  transferId String
  transfer   StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product       @relation(fields: [productId], references: [id])
  quantity   Float

  @@index([transferId])
  @@index([productId])
  @@map("stock_transfer_items")
}

// ─── INVENTORY MOVEMENTS ──────────────────────────────────────────────────────
model InventoryMovement {
  id            String       @id @default(uuid())
  productId     String
  product       Product      @relation(fields: [productId], references: [id])
  type          MovementType
  // quantity/previousStock/newStock stay Float — inventory quantities, not money
  quantity      Float
  previousStock Float
  newStock      Float
  // Monetary cost fields — enable a proper accounting ledger per movement
  unitCost      Decimal      @default(0)
  totalCost     Decimal      @default(0)
  reason        String?
  referenceId   String?
  referenceType String?
  notes         String?
  // Nullable — movimientos históricos (antes de esta función) quedan sin bodega.
  branchId      String?
  branch        Branch?      @relation(fields: [branchId], references: [id])
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([productId])
  @@index([referenceId])
  @@index([productId, createdAt])
  @@index([branchId])
  @@map("inventory_movements")
}

// ─── CUSTOMERS ────────────────────────────────────────────────────────────────
model Customer {
  id            String    @id @default(uuid())
  businessId    String?
  business      Business? @relation(fields: [businessId], references: [id])
  name          String
  document      String?
  documentType  String?   @default("CC")
  phone         String?
  email         String?
  address       String?
  city          String?
  notes         String?
  creditLimit   Decimal   @default(0)
  currentDebt   Decimal   @default(0)
  loyaltyPoints Int       @default(0)
  isActive      Boolean   @default(true)
  sales         Sale[]
  credits       Credit[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@unique([businessId, document])
  @@index([businessId])
  @@index([businessId, name])
  @@index([businessId, currentDebt])
  @@index([document])
  @@map("customers")
}

// ─── SUPPLIERS ────────────────────────────────────────────────────────────────
model Supplier {
  id          String     @id @default(uuid())
  businessId  String?
  business    Business?  @relation(fields: [businessId], references: [id])
  name        String
  legalName   String?
  document    String?
  phone       String?
  mobile      String?
  email       String?
  address     String?
  city        String?
  contactName String?
  notes       String?
  isActive    Boolean    @default(true)
  products    Product[]
  purchases   Purchase[]
  expenses    Expense[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  @@unique([businessId, document])
  @@index([businessId])
  @@map("suppliers")
}

// ─── SALES ────────────────────────────────────────────────────────────────────
model Sale {
  id             String        @id @default(uuid())
  invoiceNumber  String
  customerId     String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id])
  status         SaleStatus    @default(COMPLETED)
  subtotal       Decimal
  taxAmount      Decimal       @default(0)
  discountAmount Decimal       @default(0)
  total          Decimal
  paidAmount     Decimal
  changeAmount   Decimal       @default(0)
  paymentMethod  PaymentMethod @default(CASH)
  paymentDetails Json?
  notes          String?
  details        SaleDetail[]
  credit         Credit?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  @@unique([branchId, invoiceNumber])
  @@index([customerId])
  @@index([userId])
  @@index([branchId])
  @@index([createdAt])
  @@index([branchId, createdAt])
  @@index([status, createdAt])
  @@map("sales")
}

model SaleDetail {
  id          String   @id @default(uuid())
  saleId      String
  sale        Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Float
  unitPrice   Decimal
  costPrice   Decimal
  discountPct Decimal  @default(0)
  taxRate     Decimal  @default(0)
  subtotal    Decimal
  total       Decimal
  createdAt   DateTime @default(now())

  @@index([saleId])
  @@index([productId])
  @@map("sale_details")
}

// ─── PURCHASES ────────────────────────────────────────────────────────────────
model Purchase {
  id            String          @id @default(uuid())
  businessId    String?
  business      Business?       @relation(fields: [businessId], references: [id])
  invoiceNumber String?
  supplierId    String
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  status        PurchaseStatus  @default(COMPLETED)
  subtotal      Decimal
  taxAmount     Decimal         @default(0)
  total         Decimal
  paymentMethod PaymentMethod   @default(CASH)
  invoicePdf    String?
  notes         String?
  purchaseDate  DateTime        @default(now())
  details       PurchaseDetail[]
  // Nullable — compras históricas (antes de esta función) quedan sin bodega.
  branchId      String?
  branch        Branch?         @relation(fields: [branchId], references: [id])
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?

  @@index([supplierId])
  @@index([businessId])
  @@index([branchId])
  @@index([businessId, purchaseDate])
  @@map("purchases")
}

model PurchaseDetail {
  id         String   @id @default(uuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Float
  unitCost   Decimal
  taxRate    Decimal  @default(0)
  subtotal   Decimal
  total      Decimal
  // Nullable — detalles de antes de este campo quedan sin bodega propia; se
  // asume la de Purchase.branchId (o la más antigua del negocio) al editar/
  // eliminar. Ver legacyBranchId en purchase.routes.ts.
  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])
  createdAt  DateTime @default(now())

  @@index([purchaseId])
  @@index([productId])
  @@index([branchId])
  @@map("purchase_details")
}

// ─── EXPENSES ─────────────────────────────────────────────────────────────────
model ExpenseCategory {
  id          String    @id @default(uuid())
  businessId  String?
  business    Business? @relation(fields: [businessId], references: [id])
  name        String
  description String?
  expenses    Expense[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
  @@map("expense_categories")
}

model Expense {
  id            String           @id @default(uuid())
  businessId    String?
  business      Business?        @relation(fields: [businessId], references: [id])
  categoryId    String?
  category      ExpenseCategory? @relation(fields: [categoryId], references: [id])
  description   String
  amount        Decimal
  paymentMethod PaymentMethod    @default(CASH)
  receiptUrl        String?
  date              DateTime         @default(now())
  notes             String?
  recipientName     String?
  recipientDocument String?
  recipientPhone    String?
  supplierId        String?
  supplier          Supplier?        @relation(fields: [supplierId], references: [id])
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  deletedAt     DateTime?

  @@index([businessId])
  @@index([categoryId])
  @@index([supplierId])
  @@index([date])
  @@index([businessId, date])
  @@map("expenses")
}

// ─── CREDITS / FIADOS ─────────────────────────────────────────────────────────
model Credit {
  id          String          @id @default(uuid())
  saleId      String?         @unique
  sale        Sale?           @relation(fields: [saleId], references: [id])
  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id])
  totalAmount Decimal
  paidAmount  Decimal         @default(0)
  balance     Decimal
  status      CreditStatus    @default(PENDING)
  dueDate     DateTime?
  notes       String?
  payments    CreditPayment[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@index([status, dueDate])
  @@map("credits")
}

model CreditPayment {
  id            String        @id @default(uuid())
  creditId      String
  credit        Credit        @relation(fields: [creditId], references: [id], onDelete: Cascade)
  amount        Decimal
  paymentMethod PaymentMethod @default(CASH)
  notes         String?
  createdAt     DateTime      @default(now())

  @@index([creditId])
  @@map("credit_payments")
}

// ─── CASH REGISTER ────────────────────────────────────────────────────────────
model CashRegister {
  id             String         @id @default(uuid())
  branchId       String
  branch         Branch         @relation(fields: [branchId], references: [id])
  openedBy       String
  closedBy       String?
  openingAmount  Decimal
  closingAmount  Decimal?
  expectedAmount Decimal?
  difference     Decimal?
  status         String         @default("OPEN")
  openedAt       DateTime       @default(now())
  closedAt       DateTime?
  notes          String?
  movements      CashMovement[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([branchId])
  @@index([status])
  @@index([branchId, status])
  @@map("cash_registers")
}

model CashMovement {
  id             String       @id @default(uuid())
  cashRegisterId String
  cashRegister   CashRegister @relation(fields: [cashRegisterId], references: [id])
  type           MovementType
  amount         Decimal
  description    String
  referenceId    String?
  // Nullable — movimientos de antes de este campo quedan sin autor conocido.
  createdById    String?
  createdBy      User?        @relation(fields: [createdById], references: [id])
  createdAt      DateTime     @default(now())

  @@index([cashRegisterId])
  @@index([createdById])
  @@map("cash_movements")
}

// ─── NOTIFICATIONS ────────────────────────────────────────────────────────────
model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([userId, isRead])
  @@map("notifications")
}

// ─── AUDIT LOGS ───────────────────────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  module    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([createdAt])
  @@index([entityId])
  @@map("audit_logs")
}

// ─── INVOICE COUNTERS ─────────────────────────────────────────────────────────
model SaleNumberCounter {
  branchId  String
  dayPrefix String
  lastSeq   Int    @default(0)

  @@id([branchId, dayPrefix])
  @@map("sale_number_counters")
}