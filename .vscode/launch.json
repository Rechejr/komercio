{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend (ts-node)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--require", "ts-node/register"],
      "args": ["${workspaceFolder}/backend/src/index.ts"],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/backend/.env",
      "sourceMaps": true,
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "presentation": { "group": "dev", "order": 1 }
    },
    {
      "name": "Frontend (dev)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm.cmd",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "presentation": { "group": "dev", "order": 2 },
      "serverReadyAction": {
        "pattern": "Local:.*http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Frontend (produccion - RAPIDO)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm.cmd",
      "runtimeArgs": ["run", "start"],
      "cwd": "${workspaceFolder}/frontend",
      "console": "integratedTerminal",
      "presentation": { "group": "prod", "order": 2 },
      "serverReadyAction": {
        "pattern": "Local:.*http://localhost:(\\d+)",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    }
  ],
  "compounds": [
    {
      "name": "Dev (Backend + Frontend dev)",
      "configurations": ["Backend (ts-node)", "Frontend (dev)"],
      "stopAll": true,
      "presentation": { "group": "compounds", "order": 1 }
    },
    {
      "name": "PRODUCCION (Backend + Frontend rapido)",
      "configurations": ["Backend (ts-node)", "Frontend (produccion - RAPIDO)"],
      "stopAll": true,
      "presentation": { "group": "compounds", "order": 2 }
    }
  ]
}
