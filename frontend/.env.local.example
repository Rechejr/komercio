# Variables del frontend (Next.js).
#
# Copia este archivo a `.env.local` y ajusta los valores:
#
#   cp .env.local.example .env.local
#
# Todo lo que empieza por NEXT_PUBLIC_ queda incrustado en el bundle del
# navegador y es visible para cualquiera: aquí NUNCA van secretos.

# ─── API ──────────────────────────────────────────────────────────────────────
# URL del backend. En local, el backend corre en el puerto 4000.
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# Servidor de Socket.io para las notificaciones en tiempo real.
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ─── Opcionales ───────────────────────────────────────────────────────────────
# ID de cliente de Google OAuth. Si se deja vacío, el botón de "Continuar con
# Google" aparece atenuado y el resto del login funciona con normalidad.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# DSN de Sentry para el reporte de errores del navegador. Vacío desactiva el
# monitoreo (útil en desarrollo, para no ensuciar el proyecto con ruido local).
NEXT_PUBLIC_SENTRY_DSN=
