# Credenciales de las pruebas end-to-end.
#
# Copia este archivo a `.env` (en esta misma carpeta) y complétalo.
# `.env` está ignorado por git y NUNCA debe subirse: este repositorio es público.
#
#   cp .env.example .env
#
# Recomendación: usa un usuario dedicado a pruebas, no la cuenta de
# administrador real del negocio. Si las pruebas fallan y alguien comparte un
# reporte o un video, esas credenciales quedan expuestas.

E2E_EMAIL=usuario-de-pruebas@ejemplo.com
E2E_PASSWORD=

# URL contra la que corren las pruebas.
# Por defecto http://localhost:3001 (entorno local).
#
# ADVERTENCIA: apuntar esto a producción hace que las pruebas operen sobre datos
# de clientes reales. Si necesitas probar contra un entorno desplegado, usa un
# negocio de prueba dedicado.
E2E_BASE_URL=http://localhost:3001
